<?xml version="1.0" encoding="utf-8"?>
<!--
  email-rs Windows Installer — WiX v5
  Build (from CI, after harvest-static.py has generated static-files.wxs):

    wix build installer.wxs static-files.wxs \
      -ext WixToolset.UI.wixext \
      -ext WixToolset.Util.wixext \
      -d AppVersion=<X.Y.Z> \
      -d Staging=<abs-path-to-staging-dir> \
      -d Scripts=<abs-path-to-.woodpecker/windows> \
      -out email-rs-<X.Y.Z>.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package
    Name="email-rs"
    Version="$(var.AppVersion)"
    Manufacturer="sprooty"
    UpgradeCode="{6E4A3F9D-2B5C-4A17-89CD-F0E3B2C1A8D4}"
    InstallerVersion="500"
    Scope="perMachine"
    Compressed="yes">

    <SummaryInformation Description="email-rs — self-hosted email and calendar client" />

    <!--
      MajorUpgrade: silently remove any previously installed version before
      installing this one. Prevents side-by-side installations.
    -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of email-rs is already installed." />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Feature Id="MainFeature" Title="email-rs" Level="1">
      <ComponentGroupRef Id="AppBinaries" />
      <ComponentGroupRef Id="StaticFiles" />
    </Feature>

    <!--
      Service management via WinSW batch scripts — deferred custom actions.

      SetProperty runs immediately (not deferred), so [INSTALLDIR] etc. expand
      correctly. The resulting string becomes CustomActionData for the matching
      deferred util:WixQuietExec64 action.
      [CommonAppDataFolder] is a built-in Windows Installer property that
      expands to C:\ProgramData\ — no Directory declaration needed.
    -->
    <SetProperty Id="DoInstallService" Before="DoInstallService" Sequence="execute"
      Value="cmd.exe /c &quot;[INSTALLDIR]setup-service.bat&quot; &quot;[INSTALLDIR]&quot; &quot;[CommonAppDataFolder]email-rs\&quot;" />

    <SetProperty Id="RollbackInstallService" Before="RollbackInstallService" Sequence="execute"
      Value="cmd.exe /c &quot;[INSTALLDIR]email-rs-svc.exe&quot; uninstall" />

    <SetProperty Id="DoUninstallService" Before="DoUninstallService" Sequence="execute"
      Value="cmd.exe /c &quot;[INSTALLDIR]uninstall-service.bat&quot; &quot;[INSTALLDIR]&quot;" />

    <util:WixQuietExec64 Id="DoInstallService"   Execute="deferred" Return="check"  Impersonate="no" />
    <util:WixQuietExec64 Id="RollbackInstallService" Execute="rollback" Return="ignore" Impersonate="no" />
    <util:WixQuietExec64 Id="DoUninstallService" Execute="deferred" Return="ignore" Impersonate="no" />

    <InstallExecuteSequence>
      <Custom Action="DoUninstallService" Before="RemoveFiles">
        Installed AND REMOVE="ALL"
      </Custom>
      <Custom Action="RollbackInstallService" Before="DoInstallService">
        NOT Installed
      </Custom>
      <Custom Action="DoInstallService" After="InstallFiles">
        NOT Installed
      </Custom>
    </InstallExecuteSequence>

    <!-- Standard directory-picking wizard; supports /qn for silent install -->
    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />
  </Package>

  <!-- ── Directory layout ──────────────────────────────────────────────── -->
  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="email-rs">
        <Directory Id="STATICDIR" Name="static" />
      </Directory>
    </StandardDirectory>
  </Fragment>

  <!-- ── App binaries + service scripts ───────────────────────────────── -->
  <Fragment>
    <ComponentGroup Id="AppBinaries" Directory="INSTALLDIR">
      <Component Id="CmpEmailServer" Guid="*">
        <File Id="FileEmailServer" Source="$(var.Staging)/email-server.exe" KeyPath="yes" />
      </Component>
      <Component Id="CmpWinSW" Guid="*">
        <File Id="FileWinSW" Source="$(var.Staging)/email-rs-svc.exe" KeyPath="yes" />
      </Component>
      <Component Id="CmpSetupService" Guid="*">
        <File Id="FileSetupService" Source="$(var.Scripts)/setup-service.bat" KeyPath="yes" />
      </Component>
      <Component Id="CmpUninstallService" Guid="*">
        <File Id="FileUninstallService" Source="$(var.Scripts)/uninstall-service.bat" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>
