# Google OAuth2
# Register your app at https://console.cloud.google.com
# Add http://localhost:8585/api/v1/auth/gmail/callback as an authorised redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth2 (Outlook / Exchange)
# Register your app at https://portal.azure.com → App registrations
# Add http://localhost:8585/api/v1/auth/microsoft/callback as a redirect URI
# Required API permissions: Mail.ReadWrite, Mail.Send, offline_access
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Set automatically by docker-compose — override only if needed
# GOOGLE_REDIRECT_URI=http://localhost:8585/api/v1/auth/gmail/callback
# MICROSOFT_REDIRECT_URI=http://localhost:8585/api/v1/auth/microsoft/callback
# DATABASE_URL=sqlite:///data/email.db
